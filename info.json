{
  "id": "plugin.com.tingzhong666.deepseek",
  "plugin_type": "translate",
  "icon": "deepseek.svg",
  "display": "deepseek",
  "homepage": "https://github.com/tingzhong666/pot-app-translate-plugin-deepseek",
  "needs": [
    {
      "key": "model",
      "display": "模型选择",
      "type": "input",
      "default": "deepseek-v4-flash"
    },
    {
      "key": "apiKey",
      "display": "API密钥",
      "type": "input"
    },
    {
      "key": "systemPrompt ",
      "display": "系统提示",
      "type": "input",
      "default": "You are a professional translation engine, please translate the text into a colloquial, professional, elegant and fluent content, without the style of machine translation. You must only translate the text content, never interpret it."
    }
  ],
  "language": {
    "auto": "auto",
    "zh_cn": "zh",
    "zh_tw": "zh_HANT",
    "en": "en",
    "ja": "ja",
    "ko": "ko",
    "fr": "fr",
    "es": "es",
    "ru": "ru",
    "de": "de",
    "it": "it",
    "tr": "tr",
    "pt_pt": "pt",
    "pt_br": "pt",
    "vi": "vi",
    "id": "id",
    "th": "th",
    "ms": "ms",
    "ar": "ar",
    "hi": "hi",
    "mn_cy": "mn",
    "mn_mo": "mn",
    "km": "km",
    "nb_no": "no",
    "nn_no": "no",
    "fa": "fa"
  }
}